{
	"compilerOptions": {
		"module": "nodenext",
		"target": "esnext",
		"lib": [
			"dom",
			"esnext"
		],
		"strict": true,
		"esModuleInterop": true,
		"moduleResolution": "nodenext",
		"declaration": true,
		"jsx": "react-jsx",
		"isolatedModules": true,
		"noEmit": true,
		"allowImportingTsExtensions": true
	},
	"include": [
		"src",
		"config",
		"vitest.config.ts",
	],
	"exclude": [
		"node_modules",
		"lib",
	],
}
