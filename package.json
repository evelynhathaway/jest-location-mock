{
	"name": "jest-location-mock",
	"version": "3.0.0-alpha.1",
	"description": "Jest hooks for JSDOM location mock",
	"keywords": [
		"jest",
		"jsdom",
		"location"
	],
	"homepage": "https://github.com/evelynhathaway/jest-location-mock#readme",
	"bugs": {
		"url": "https://github.com/evelynhathaway/jest-location-mock/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evelynhathaway/jest-location-mock.git"
	},
	"license": "MIT",
	"author": "Evelyn Hathaway <npm@evelyn.dev> (https://evelyn.dev)",
	"sideEffects": true,
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"directories": {
		"lib": "/lib",
		"src": "/src"
	},
	"files": [
		"/lib",
		"/jest.d.ts"
	],
	"scripts": {
		"build": "tsc -p ./tsconfig-build.json",
		"lint": "eslint",
		"prepare": "husky",
		"test": "jest"
	},
	"commitlint": {
		"extends": "./node_modules/conventional-changelog-evelyn/commitlint.config.js"
	},
	"lint-staged": {
		"**/package.json": "sort-package-json",
		"./": "eslint --fix"
	},
	"release": {
		"extends": "conventional-changelog-evelyn/release.config.js"
	},
	"dependencies": {
		"@jedmao/location": "^3.0.0"
	},
	"devDependencies": {
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/jest": "^30.0.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"commitlint": "^20.4.3",
		"conventional-changelog-evelyn": "^2.0.1",
		"eslint": "^9.39.3",
		"eslint-plugin-evelyn": "^12.1.0",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"lint-staged": "^16.3.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.1",
		"semantic-release": "^25.0.3",
		"sort-package-json": "^3.6.1",
		"ts-jest": "^29.4.6",
		"typescript": "^5.9.3",
		"whatwg-fetch": "^3.6.20"
	},
	"peerDependencies": {
		"@jest/globals": "^30.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
